class Solution(object):
    def numIdenticalPairs(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        pairs = {}
        count = 0
        for i in range(len(nums)):
            if nums[i] in pairs:
                count += pairs[nums[i]]
            pairs[nums[i]] = pairs.get(nums[i], 0) + 1
        return count
