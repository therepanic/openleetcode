class Solution(object):
    def winnerSquareGame(self, n):
        """
        :type n: int
        :rtype: bool
        """
        import math
        memo = {}
        def dp(player, stones):
            if stones == 0:
                return False
            if (player, stones) in memo:
                return memo[(player, stones)]
            sqrt = int(math.sqrt(stones))
            for i in range(sqrt, 0, -1):
                if i * i == stones or not dp(player ^ 1, stones - i * i):
                    memo[(player, stones)] = True
                    return True
            memo[(player, stones)] = False
            return False
        return dp(0, n)
