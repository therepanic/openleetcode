class Solution(object):
    def canMakeArithmeticProgression(self, arr):
        """
        :type arr: List[int]
        :rtype: bool
        """
        arr.sort()
        li=arr[1]-arr[0]
        for i in range(len(arr)-1):
            m=arr[i+1]-arr[i]
            if li != m:
                return False
        return True
