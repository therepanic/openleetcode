class Solution(object):
    def getLastMoment(self, n, left, right):
        """
        :type n: int
        :type left: List[int]
        :type right: List[int]
        :rtype: int
        """
        max_val = 0
        for value in left:
            max_val = max(value, max_val)
        for value in right:
            max_val = max(n - value, max_val)
        return max_val
