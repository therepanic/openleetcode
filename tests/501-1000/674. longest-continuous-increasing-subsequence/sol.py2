class Solution(object):
    def findLengthOfLCIS(self, nums):
        ptr1, ptr2 = 0, 1
        n = len(nums)
        if n == 0:
            return 0
        maxLenSubseq = 1
        while ptr2 < n:
            while ptr2 < n and nums[ptr2] > nums[ptr2 - 1]:
                ptr2 += 1
            maxLenSubseq = max(maxLenSubseq, ptr2 - ptr1)
            ptr1 = ptr2
            ptr2 += 1
        return maxLenSubseq
