class Solution(object):
    def preimageSizeFZF(self, k):
        """
        :type k: int
        :rtype: int
        """
        def trailingZeroes(n):
            count = 0
            power = 5
            while power <= n:
                count += n // power
                power *= 5
            return count
        
        start = k * 4
        while True:
            H = trailingZeroes(start)
            if H == k:
                return 5
            if H > k:
                break
            start += 1
        return 0
