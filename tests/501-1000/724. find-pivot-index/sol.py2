class Solution(object):
    def pivotIndex(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        totalSum = sum(nums)
        lSum = 0
        rSum = totalSum
        for i in range(len(nums)):
            rSum -= nums[i]
            if lSum == rSum:
                return i
            lSum += nums[i]
        return -1
