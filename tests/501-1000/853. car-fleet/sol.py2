class Solution(object):
    def carFleet(self, target, position, speed):
        """
        :type target: int
        :type position: List[int]
        :type speed: List[int]
        :rtype: int
        """
        cars = sorted(zip(position, speed), reverse=True)
        stack = []
        for p, s in cars:
            t = float(target - p) / s
            if not stack or t > stack[-1]:
                stack.append(t)
        return len(stack)
