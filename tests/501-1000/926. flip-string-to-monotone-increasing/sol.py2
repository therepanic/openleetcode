class Solution(object):
    def minFlipsMonoIncr(self, s):
        """
        :type s: str
        :rtype: int
        """
        zeroes = 0
        ones = 0
        
        for ch in s:
            if ch == '0':
                zeroes += 1
        
        output = zeroes
        
        for ch in s:
            if ch == '0':
                zeroes -= 1
            elif ch == '1':
                ones += 1
            output = min(output, zeroes + ones)
        
        return output
