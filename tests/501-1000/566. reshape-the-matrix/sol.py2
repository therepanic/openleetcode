class Solution(object):
    def matrixReshape(self, mat, r, c):
        """
        :type mat: List[List[int]]
        :type r: int
        :type c: int
        :rtype: List[List[int]]
        """
        m, n = len(mat), len(mat[0])
        if m * n != r * c:
            return mat
        
        reshaped = [[0] * c for _ in range(r)]
        count = 0
        
        for i in range(m):
            for j in range(n):
                reshaped[count // c][count % c] = mat[i][j]
                count += 1
        
        return reshaped
