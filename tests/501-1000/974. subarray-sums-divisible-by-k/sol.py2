class Solution(object):
    def subarraysDivByK(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        s = 0
        res = 0
        hs = {0: 1}
        for num in nums:
            s += num
            rem = s % k
            res += hs.get(rem, 0)
            hs[rem] = hs.get(rem, 0) + 1
        return res
