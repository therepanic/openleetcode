class Solution(object):
    def partitionLabels(self, s):
        """
        :type s: str
        :rtype: List[int]
        """
        last = [0] * 26
        for i in range(len(s)):
            last[ord(s[i]) - ord('a')] = i
        ans = []
        start = 0
        end = 0
        for i in range(len(s)):
            if last[ord(s[i]) - ord('a')] > end:
                end = last[ord(s[i]) - ord('a')]
            if i == end:
                ans.append(end - start + 1)
                start = i + 1
        return ans
