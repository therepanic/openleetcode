class Solution(object):
    def matrixScore(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: int
        """
        rows, cols = len(grid), len(grid[0])
        for row in grid:
            if row[0] == 0:
                for i in range(cols):
                    row[i] ^= 1
        for j in range(1, cols):
            temp = 0
            for i in range(rows):
                temp += grid[i][j]
            if 2 * temp < rows:
                for i in range(rows):
                    grid[i][j] ^= 1
        ans = 0
        for row in grid:
            val = ''.join(map(str, row))
            ans += int(val, 2)
        return ans
