class Solution(object):
    def widthOfBinaryTree(self, root):
        q = deque([root])
        ind = deque([0])
        max_width = 0

        while q:
            first = None
            last = None
            for _ in range(len(q)):
                node = q.popleft()
                i = ind.popleft()
                if node:
                    if first is None:
                        first = i
                    last = i
                    q.append(node.left)
                    ind.append(2 * i + 1)
                    q.append(node.right)
                    ind.append(2 * i + 2)
            if first is not None:
                max_width = max(max_width, last - first + 1)
        return max_width
