class Solution(object):
    def movesToChessboard(self, board):
        """
        :type board: List[List[int]]
        :rtype: int
        """
        n = len(board)
        
        def fn(vals):
            total = 0
            odd = 0
            for i, x in enumerate(vals):
                if vals[0] == x:
                    total += 1
                    if i & 1:
                        odd += 1
                elif vals[0] ^ x != (1 << n) - 1:
                    return float('inf')
            ans = float('inf')
            if n <= 2 * total <= n + 1:
                ans = min(ans, odd)
            if n - 1 <= 2 * total <= n:
                ans = min(ans, total - odd)
            return ans
        
        rows = [0] * n
        cols = [0] * n
        for i in range(n):
            for j in range(n):
                if board[i][j]:
                    rows[i] ^= 1 << j
                    cols[j] ^= 1 << i
        ans = fn(rows) + fn(cols)
        return ans if ans < float('inf') else -1
