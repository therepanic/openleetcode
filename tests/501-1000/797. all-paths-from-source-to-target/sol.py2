class Solution(object):
    def allPathsSourceTarget(self, graph):
        """
        :type graph: List[List[int]]
        :rtype: List[List[int]]
        """
        queue = [(0, [0])]
        target = len(graph) - 1
        result = []

        while queue:
            node, path = queue.pop(0)
            if node == target:
                result.append(path)
                continue
            for neighbor in graph[node]:
                queue.append((neighbor, path + [neighbor]))

        return result
