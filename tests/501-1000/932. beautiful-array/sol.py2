class Solution(object):
    def beautifulArray(self, n):
        """
        :type n: int
        :rtype: List[int]
        """
        if n == 1:
            return [1]
        
        left = self.beautifulArray((n + 1) // 2)
        right = self.beautifulArray(n // 2)
        
        left = [2 * x - 1 for x in left]
        right = [2 * x for x in right]
        
        return left + right
