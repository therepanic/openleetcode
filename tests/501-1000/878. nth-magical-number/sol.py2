class Solution(object):
    def nthMagicalNumber(self, n, a, b):
        """
        :type n: int
        :type a: int
        :type b: int
        :rtype: int
        """
        MOD = 1000000007
        g = self._gcd(a, b)
        lcm = a // g * b
        lo, hi = min(a, b), n * min(a, b)
        while lo < hi:
            mid = (lo + hi) >> 1
            cnt = mid // a + mid // b - mid // lcm
            if cnt < n:
                lo = mid + 1
            else:
                hi = mid
        return lo % MOD
    
    def _gcd(self, x, y):
        while y:
            x, y = y, x % y
        return x
