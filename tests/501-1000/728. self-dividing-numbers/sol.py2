class Solution(object):
    def selfDividingNumbers(self, left, right):
        """
        :type left: int
        :type right: int
        :rtype: List[int]
        """
        lst = []

        for i in range(left,right+1):
            temp=[int(x) for x in str(i)]
            if 0 in temp:
                continue
            else:
                b=1
                for j in temp:
                    if i%j==0:
                        continue
                    else:
                        b=0
                if b==1:
                    lst.append(i)
        return lst
