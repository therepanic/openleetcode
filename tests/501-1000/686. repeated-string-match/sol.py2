class Solution(object):
    def repeatedStringMatch(self, a, b):
        """
        :type a: str
        :type b: str
        :rtype: int
        """
        repeatA = a
        count = 1

        while len(repeatA) < len(b):
            repeatA += a
            count += 1
            if b in repeatA:
                return count

        repeatA += a
        count += 1
        if b in repeatA:
            return count

        return -1
