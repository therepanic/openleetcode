class Solution(object):
    def distinctSubseqII(self, s):
        """
        :type s: str
        :rtype: int
        """
        n = len(s)
        dp = [0] * n
        dp[0] = 2
        mp = {}
        mp[s[0]] = 0
        mod = 10**9 + 7
        for i in range(1, n):
            dp[i] = 2 * dp[i-1]
            if s[i] in mp:
                dp[i] -= dp[mp[s[i]]-1] if mp[s[i]] > 0 else 1
            mp[s[i]] = i
            dp[i] %= mod
        return (dp[-1] - 1 + mod) % mod
