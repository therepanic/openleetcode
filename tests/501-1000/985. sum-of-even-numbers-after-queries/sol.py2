class Solution(object):
    def sumEvenAfterQueries(self, nums, queries):
        """
        :type nums: List[int]
        :type queries: List[List[int]]
        :rtype: List[int]
        """
        total = sum(x for x in nums if x % 2 == 0)
        ans = []
        for val, idx in queries:
            if nums[idx] % 2 == 0:
                total -= nums[idx]
            nums[idx] += val
            if nums[idx] % 2 == 0:
                total += nums[idx]
            ans.append(total)
        return ans
