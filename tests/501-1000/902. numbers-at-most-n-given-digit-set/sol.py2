class Solution(object):
    def atMostNGivenDigitSet(self, digits, n):
        """
        :type digits: List[str]
        :type n: int
        :rtype: int
        """
        d = len(digits)
        s = str(n)
        k = len(s)
        
        ans = 0
        if d == 1:
            ans = k - 1
        else:
            ans = (d**k - d) // (d - 1)
        
        for i, ch in enumerate(s):
            cnt = sum(1 for digit in digits if digit < ch)
            ans += cnt * (d ** (k - i - 1))
            if ch not in digits:
                break
        else:
            ans += 1
        
        return ans
