class Solution(object):
    def arrayNesting(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        max_count = 0
        
        for i in range(len(nums)):
            if nums[i] == -1:
                continue
                
            current_count = 0
            start = i
            
            while nums[start] != -1:
                next_node = nums[start]
                nums[start] = -1
                start = next_node
                current_count += 1
                
            if current_count > max_count:
                max_count = current_count
                
        return max_count
