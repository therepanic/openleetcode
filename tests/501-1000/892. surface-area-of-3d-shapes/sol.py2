class Solution(object):
    def surfaceArea(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: int
        """
        n = len(grid)
        area = 0
        for i in range(n):
            for j in range(n):
                if grid[i][j]:
                    area += grid[i][j] * 6
                    area -= (grid[i][j] - 1) * 2
                    if i + 1 < n:
                        area -= 2 * min(grid[i][j], grid[i + 1][j])
                    if j + 1 < n:
                        area -= 2 * min(grid[i][j], grid[i][j + 1])
        return area
