class Solution(object):
    def findAndReplacePattern(self, words, pattern):
        """
        :type words: List[str]
        :type pattern: str
        :rtype: List[str]
        """
        counts = [pattern.index(c) for c in pattern]
        res = []
        for word in words:
            count = []
            for c in word:
                count.append(word.index(c))
            if count == counts:
                res.append(word)
        return res
