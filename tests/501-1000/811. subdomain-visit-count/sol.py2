class Solution(object):
    def subdomainVisits(self, cpdomains):
        """
        :type cpdomains: List[str]
        :rtype: List[str]
        """
        freq = {}
        for entry in cpdomains:
            cnt, dom = entry.split()
            cnt = int(cnt)
            parts = dom.split('.')
            for i in range(len(parts)):
                sub = '.'.join(parts[i:])
                freq[sub] = freq.get(sub, 0) + cnt
        return ["{} {}".format(c, d) for d, c in freq.items()]
