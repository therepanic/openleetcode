class Solution(object):
    def pancakeSort(self, arr):
        """
        :type arr: List[int]
        :rtype: List[int]
        """
        n = len(arr)
        result = []
        
        for i in range(n):
            target = n - i
            position = 0
            
            for j in range(n - i):
                if arr[j] == target:
                    position = j
                    break
            
            if position == n - i - 1:
                continue
                
            if position > 0:
                result.append(position + 1)
                arr[:position + 1] = arr[:position + 1][::-1]
                
            result.append(n - i)
            arr[:n - i] = arr[:n - i][::-1]
            
        return result
