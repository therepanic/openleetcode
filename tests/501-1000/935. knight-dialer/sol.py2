class Solution(object):
    def knightDialer(self, n):
        """
        :type n: int
        :rtype: int
        """
        if n == 1:
            return 10
        
        dp = [1] * 10
        mapping = {0: [4, 6],
                   1: [6, 8],
                   2: [7, 9],
                   3: [4, 8],
                   4: [0, 3, 9],
                   5: [],
                   6: [0, 1, 7],
                   7: [2, 6],
                   8: [1, 3],
                   9: [2, 4]}
        
        for _ in range(n - 1):
            new = [0] * 10
            for i in range(10):
                for digit in mapping[i]:
                    new[digit] += dp[i]
            dp = new
        
        return int(sum(dp) % (10**9 + 7))
