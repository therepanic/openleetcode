class Solution(object):
    def scheduleCourse(self, courses):
        """
        :type courses: List[List[int]]
        :rtype: int
        """
        import heapq
        courses.sort(key=lambda x: (x[1], x[0]))
        heap = []
        days = 0
        for duration, last in courses:
            days += duration
            heapq.heappush(heap, -duration)
            if days > last:
                top = heapq.heappop(heap)
                days += top
        return len(heap)
