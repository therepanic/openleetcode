class Solution(object):
    def optimalDivision(self, nums):
        result = str(nums[0])
        if len(nums) == 1:
            return result
            
        if len(nums) == 2:
            return result + '/' + str(nums[1])
            
        result += '/(' + str(nums[1])
        for num in nums[2:]:
            result += '/' + str(num)
            
        return result + ')'
