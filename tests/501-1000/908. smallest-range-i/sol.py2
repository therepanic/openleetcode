class Solution(object):
    def smallestRangeI(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        min_val = nums[0]
        max_val = nums[0]
        
        for val in nums:
            if val < min_val:
                min_val = val
            elif val > max_val:
                max_val = val
        
        return max(0, max_val - min_val - k * 2)
