class Solution(object):
    def shiftingLetters(self, s, shifts):
        l=[]
        z=sum(shifts)
        l.append(z)
        for i in range(1,len(shifts)):
            l.append(l[-1]-shifts[i-1])
        p=[]
        for i in range(len(s)):
            p.append(ord(s[i])-97)
        k=""
        for i in range(len(p)):
            k=k+chr(((p[i]+l[i])%26)+97)
        return k
