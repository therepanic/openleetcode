class Solution(object):
    def bestRotation(self, nums):
        n = len(nums)
        diffs = [0] * (n + 1)
        for i, num in enumerate(nums):
            left = (i - num + 1) % n
            right = (i + 1) % n
            diffs[left] -= 1
            diffs[right] += 1
            if left > right:
                diffs[0] -= 1
        best = 0
        cur = n
        max_score = cur
        for k in range(1, n):
            cur += diffs[k]
            if cur > max_score:
                max_score = cur
                best = k
        return best
