class Solution(object):
    def findKthNumber(self, m, n, k):
        """
        :type m: int
        :type n: int
        :type k: int
        :rtype: int
        """
        lo, hi = 1, m * n
        while lo < hi:
            mid = (lo + hi) // 2
            count = 0
            for i in range(1, m + 1):
                count += n if n < mid // i else mid // i
            if count >= k:
                hi = mid
            else:
                lo = mid + 1
        return lo
