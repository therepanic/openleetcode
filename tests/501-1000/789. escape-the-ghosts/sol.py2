class Solution(object):
    def escapeGhosts(self, ghosts, target):
        """
        :type ghosts: List[List[int]]
        :type target: List[int]
        :rtype: bool
        """
        def moves(x, y):
            count = 0
            count += abs(x[0] - y[0])
            count += abs(x[1] - y[1])
            return count
        
        a = []
        for i in ghosts:
            a.append(moves(i, target))
        
        z = moves(target, [0, 0])
        
        ans = True
        for i in a:
            if i <= z:
                ans = False
        
        return ans
