class Solution(object):
    def dominantIndex(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        m = -1
        s = -1
        idx = -1
        for i, x in enumerate(nums):
            if x > m:
                s = m
                m = x
                idx = i
            elif x > s:
                s = x
        return idx if m >= s * 2 else -1
