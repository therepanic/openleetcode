class Solution(object):
    def canVisitAllRooms(self, rooms):
        """
        :type rooms: List[List[int]]
        :rtype: bool
        """
        n = len(rooms)
        keys = [0]
        visited = {0}
        while keys:
            room = keys.pop()
            for i in rooms[room]:
                if i not in visited:
                    visited.add(i)
                    keys.append(i)
        return len(visited) == n
