class Solution(object):
    def xorGame(self, nums):
        """
        :type nums: List[int]
        :rtype: bool
        """
        totalXor = 0
        for value in nums:
            totalXor ^= value
        
        isXorZero = (totalXor == 0)
        hasEvenLength = (len(nums) % 2 == 0)
        
        return isXorZero or hasEvenLength
