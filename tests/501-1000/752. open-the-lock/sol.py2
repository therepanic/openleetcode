class Solution(object):
    def openLock(self, deadends, target):
        """
        :type deadends: List[str]
        :type target: str
        :rtype: int
        """
        if target == "0000":
            return 0
        deadends_set = set(deadends)
        if "0000" in deadends_set:
            return -1
        
        from collections import deque
        moves = 0
        queue = deque(["0000"])
        visited = set(["0000"])
        
        def neighbors(lock):
            result = []
            for i in range(4):
                val = int(lock[i])
                up = (val + 1) % 10
                down = (val - 1) % 10
                result.append(lock[:i] + str(up) + lock[i+1:])
                result.append(lock[:i] + str(down) + lock[i+1:])
            return result
        
        while queue:
            for _ in range(len(queue)):
                cur = queue.popleft()
                if cur == target:
                    return moves
                for nxt in neighbors(cur):
                    if nxt not in deadends_set and nxt not in visited:
                        visited.add(nxt)
                        queue.append(nxt)
            moves += 1
        return -1
