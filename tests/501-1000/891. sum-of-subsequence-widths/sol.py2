class Solution(object):
    def sumSubseqWidths(self, nums):
        mod = 1000000007
        nums.sort()
        n = len(nums)
        ans = 0
        factor = 1
        for i in range(n):
            ans = (ans + (nums[i] - nums[~i]) * factor) % mod
            factor = (factor * 2) % mod
        return ans
