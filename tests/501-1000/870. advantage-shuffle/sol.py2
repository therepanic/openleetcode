class Solution(object):
    def advantageCount(self, nums1, nums2):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :rtype: List[int]
        """
        n = len(nums1)
        nums1.sort()
        order = sorted(xrange(n), key=nums2.__getitem__)
        res = [0] * n

        left, right = 0, n - 1
        for i in xrange(n - 1, -1, -1):
            pos = order[i]
            if nums1[right] > nums2[pos]:
                res[pos] = nums1[right]
                right -= 1
            else:
                res[pos] = nums1[left]
                left += 1
        return res
