class Solution(object):
    def reverseParentheses(self, s):
        """
        :type s: str
        :rtype: str
        """
        self.i = 0
        return self.helper(s)

    def helper(self, s):
        size = len(s)
        ans = ""

        while self.i < size:
            if s[self.i] == '(':
                self.i += 1
                ans += self.helper(s)
            elif s[self.i] == ')':
                self.i += 1
                return self.rev(ans)
            else:
                ans += s[self.i]
                self.i += 1

        return ans

    def rev(self, s):
        r = ""
        for i in range(0, len(s)):
            r = s[i] + r
        return r
