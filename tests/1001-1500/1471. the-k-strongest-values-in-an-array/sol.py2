class Solution(object):
    def getStrongest(self, arr, k):
        """
        :type arr: List[int]
        :type k: int
        :rtype: List[int]
        """
        arr.sort()
        m = arr[(len(arr) - 1) // 2]
        
        left, right = 0, len(arr) - 1
        result = []
        for _ in range(k):
            if abs(arr[right] - m) >= abs(arr[left] - m):
                result.append(arr[right])
                right -= 1
            else:
                result.append(arr[left])
                left += 1
        return result
