class Solution(object):
    def arrayRankTransform(self, arr):
        """
        :type arr: List[int]
        :rtype: List[int]
        """
        s = sorted(arr)
        unique = []
        for x in s:
            if not unique or unique[-1] != x:
                unique.append(x)
        for i in range(len(arr)):
            arr[i] = self._bisect_left(unique, arr[i]) + 1
        return arr
    
    def _bisect_left(self, a, x):
        lo, hi = 0, len(a)
        while lo < hi:
            mid = (lo + hi) // 2
            if a[mid] < x:
                lo = mid + 1
            else:
                hi = mid
        return lo
