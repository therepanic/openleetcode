class Solution(object):
    def isPossibleDivide(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: bool
        """
        if len(nums) % k != 0:
            return False
        from collections import Counter
        count = Counter(nums)
        nums.sort()
        for num in nums:
            if count[num] == 0:
                continue
            for i in range(k):
                if count[num + i] == 0:
                    return False
                count[num + i] -= 1
        return True
