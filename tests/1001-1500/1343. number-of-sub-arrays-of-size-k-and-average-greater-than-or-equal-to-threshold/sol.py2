class Solution(object):
    def numOfSubarrays(self, arr, k, threshold):
        """
        :type arr: List[int]
        :type k: int
        :type threshold: int
        :rtype: int
        """
        res = 0
        left = 0
        total = 0
        for right in range(len(arr)):
            total += arr[right]
            if right - left + 1 == k:
                if total // k >= threshold:
                    res += 1
                total -= arr[left]
                left += 1
        return res
