class Solution(object):
    def kthSmallest(self, mat, k):
        """
        :type mat: List[List[int]]
        :type k: int
        :rtype: int
        """
        sums = mat[0][:k]
        for row in mat[1:]:
            sums = sorted(a + b for a in sums for b in row[:k])[:k]
        return sums[k - 1]
