class Solution(object):
    def canBeEqual(self, target, arr):
        """
        :type target: List[int]
        :type arr: List[int]
        :rtype: bool
        """
        counts = [0] * 1001
        
        for t, a in zip(target, arr):
            counts[t] += 1
            counts[a] -= 1
            
        return not any(counts)
