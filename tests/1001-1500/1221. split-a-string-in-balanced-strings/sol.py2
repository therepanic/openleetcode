class Solution(object):
    def balancedStringSplit(self, s):
        """
        :type s: str
        :rtype: int
        """
        Bal = 0
        count = 0
        for c in s:
            if c == 'L':
                Bal += 1
            elif c == 'R':
                Bal -= 1
            if Bal == 0:
                count += 1
        return count
