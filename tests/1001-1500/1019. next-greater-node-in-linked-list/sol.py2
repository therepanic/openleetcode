class Solution(object):
    def nextLargerNodes(self, head):
        arr = []
        while head:
            arr.append(head.val)
            head = head.next
        n = len(arr)
        ans = [0] * n
        stack = []
        for i in range(n):
            while stack and arr[i] > arr[stack[-1]]:
                ans[stack.pop()] = arr[i]
            stack.append(i)
        return ans
