# Definition for a binary tree node.
# class TreeNode(object):
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution(object):
    def maxLevelSum(self, root):
        """
        :type root: Optional[TreeNode]
        :rtype: int
        """
        from collections import deque
        idx, max_sum = 0, float('-inf')
        q = deque([root])
        level = 1
        while q:
            qz = len(q)
            cur_sum = 0
            for _ in range(qz):
                node = q.popleft()
                cur_sum += node.val
                if node.left:
                    q.append(node.left)
                if node.right:
                    q.append(node.right)
            if cur_sum > max_sum:
                idx, max_sum = level, cur_sum
            level += 1
        return idx
