from collections import Counter


class Solution(object):
    def commonChars(self, words):
        chars = list(words[0])
        freq = Counter(chars)
        for word in words[1:]:
            f = Counter(word)
            for c in list(freq.keys()):
                if c in f:
                    freq[c] = min(f[c], freq[c])
                else:
                    freq[c] = 0
        res = []
        for x in freq:
            if freq[x] != 0:
                res.extend([x] * freq[x])
        return res
