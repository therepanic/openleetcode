class Solution(object):
    def parseBoolExpr(self, expression):
        st = []
        for ch in expression:
            if ch == ',':
                continue
            if ch != ')':
                st.append(ch)
                continue
            has_true = False
            has_false = False
            while st[-1] != '(':
                v = st.pop()
                if v == 't':
                    has_true = True
                if v == 'f':
                    has_false = True
            st.pop()
            op = st.pop()
            if op == '!':
                st.append('f' if has_true else 't')
            elif op == '&':
                st.append('f' if has_false else 't')
            else:
                st.append('t' if has_true else 'f')
        return st[0] == 't'
