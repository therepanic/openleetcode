class Solution(object):
    def minRemoveToMakeValid(self, s):
        """
        :type s: str
        :rtype: str
        """
        t = []
        p = 0
        for c in s:
            if c == '(':
                p += 1
            elif c == ')':
                p -= 1
            if p >= 0:
                t.append(c)
            else:
                p = 0
        p = 0
        result = []
        for c in reversed(t):
            if c == '(':
                p += 1
            elif c == ')':
                p -= 1
            if p <= 0:
                result.append(c)
            else:
                p = 0
        return ''.join(reversed(result))
