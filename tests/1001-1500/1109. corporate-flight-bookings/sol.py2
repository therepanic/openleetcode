class Solution(object):
    def corpFlightBookings(self, bookings, n):
        """
        :type bookings: List[List[int]]
        :type n: int
        :rtype: List[int]
        """
        l = [0] * (n + 1)
        for i in bookings:
            x = i[0]
            y = i[1]
            l[x - 1] += i[-1]
            l[y] -= i[-1]
        
        s = []
        for i in range(len(l) - 1):
            if i == 0:
                s.append(l[i])
            else:
                s.append(s[-1] + l[i])
        return s
