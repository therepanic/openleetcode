class Solution(object):
    def entityParser(self, text):
        """
        :type text: str
        :rtype: str
        """
        entities = {
            "&quot": '"',
            "&apos": "'",
            "&amp": "&",
            "&gt": ">",
            "&lt": "<",
            "&frasl": "/"
        }
        
        import re
        pattern = r'&[^;&\s]+;'
        
        def replacer(match):
            entity = match.group(0)[:-1]
            return entities.get(entity, match.group(0))
        
        return re.sub(pattern, replacer, text)
