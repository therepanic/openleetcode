class Solution(object):
    def longestDupSubstring(self, s):
        """
        :type s: str
        :rtype: str
        """
        n = len(s)
        base1, base2 = 131, 31
        mod1, mod2 = 10**9+5, 10**9+7

        def build(base, mod):
            h = [0]*(n+1)
            p = [1]*(n+1)
            for i in range(n):
                h[i+1] = (h[i]*base + ord(s[i])) % mod
                p[i+1] = (p[i]*base) % mod
            return h, p

        def get(h, p, l, r, mod):
            return (h[r] - h[l]*p[r-l]) % mod

        h1, p1 = build(base1, mod1)
        h2, p2 = build(base2, mod2)

        def check(L):
            seen = set()
            for i in range(n-L+1):
                x = (get(h1, p1, i, i+L, mod1),
                     get(h2, p2, i, i+L, mod2))
                if x in seen:
                    return s[i:i+L]
                seen.add(x)
            return ""

        lo, hi, res = 1, n, ""
        while lo <= hi:
            mid = (lo + hi) // 2
            t = check(mid)
            if t:
                res, lo = t, mid + 1
            else:
                hi = mid - 1
        return res
