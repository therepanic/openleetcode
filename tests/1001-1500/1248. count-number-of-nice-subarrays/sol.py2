class Solution(object):
    def numberOfSubarrays(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        count = {0: 1}
        odd = 0
        answer = 0
        for value in nums:
            odd += value % 2
            answer += count.get(odd - k, 0)
            count[odd] = count.get(odd, 0) + 1
        return answer
