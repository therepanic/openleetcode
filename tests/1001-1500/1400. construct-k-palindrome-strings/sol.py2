class Solution(object):
    def canConstruct(self, s, k):
        """
        :type s: str
        :type k: int
        :rtype: bool
        """
        if len(s) < k:
            return False

        char_count = {}
        for c in s:
            char_count[c] = char_count.get(c, 0) + 1

        odd_count = sum(freq % 2 for freq in char_count.values())
        return odd_count <= k
