class Solution(object):
    def printVertically(self, s):
        """
        :type s: str
        :rtype: List[str]
        """
        words = s.split()
        max_len = max(len(word) for word in words)
        res = []
        for i in range(max_len):
            curr_word = ""
            for word in words:
                if i < len(word):
                    curr_word += word[i]
                else:
                    curr_word += " "
            res.append(curr_word.rstrip())
        return res
