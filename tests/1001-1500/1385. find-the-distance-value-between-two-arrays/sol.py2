class Solution(object):
    def findTheDistanceValue(self, arr1, arr2, d):
        """
        :type arr1: List[int]
        :type arr2: List[int]
        :type d: int
        :rtype: int
        """
        import bisect
        arr2.sort()
        count = 0
        for num in arr1:
            left_index = bisect.bisect_left(arr2, num - d)
            right_index = bisect.bisect_right(arr2, num + d)
            if left_index == right_index:
                count += 1
        return count
