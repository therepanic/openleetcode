class Solution(object):
    def allCellsDistOrder(self, rows, cols, rCenter, cCenter):
        """
        :type rows: int
        :type cols: int
        :type rCenter: int
        :type cCenter: int
        :rtype: List[List[int]]
        """
        return sorted([[r, c] for r in range(rows) for c in range(cols)], key=lambda p: abs(p[0] - rCenter) + abs(p[1] - cCenter))
