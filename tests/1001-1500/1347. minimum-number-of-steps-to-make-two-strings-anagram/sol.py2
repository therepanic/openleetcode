class Solution(object):
    def minSteps(self, s, t):
        """
        :type s: str
        :type t: str
        :rtype: int
        """
        dic = {}
        for ch in t:
            dic[ch] = dic.get(ch, 0) + 1
        for ch in s:
            if ch in dic and dic[ch] > 0:
                dic[ch] -= 1
        return sum(dic.values())
