class Solution(object):
    def longestPrefix(self, s):
        """
        :type s: str
        :rtype: str
        """
        n = len(s)
        prefix = [0] * n
        matched = 0
        for i in range(1, n):
            while matched and s[i] != s[matched]:
                matched = prefix[matched - 1]
            if s[i] == s[matched]:
                matched += 1
            prefix[i] = matched
        return s[:prefix[-1]]
