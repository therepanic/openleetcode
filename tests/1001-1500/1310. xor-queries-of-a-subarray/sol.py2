class Solution(object):
    def xorQueries(self, arr, queries):
        """
        :type arr: List[int]
        :type queries: List[List[int]]
        :rtype: List[int]
        """
        prefix = [0]
        for num in arr:
            prefix.append(prefix[-1] ^ num)
        return [prefix[b + 1] ^ prefix[a] for a, b in queries]
