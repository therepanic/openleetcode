class Solution(object):
    def groupThePeople(self, groupSizes):
        """
        :type groupSizes: List[int]
        :rtype: List[List[int]]
        """
        from collections import defaultdict
        ans = []
        mp = defaultdict(list)
        for i, val in enumerate(groupSizes):
            if len(mp[val]) < val:
                mp[val].append(i)
                if len(mp[val]) == val:
                    ans.append(mp[val])
                    mp[val] = []
        return ans
