class Solution(object):
    def movesToMakeZigzag(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        n = len(nums)

        def find_valleys(mode):
            res = 0
            for i in range(n):
                if i % 2 == mode:
                    left = nums[i-1] if i-1 >= 0 else float('inf')
                    right = nums[i+1] if i+1 < n else float('inf')
                    min_neighbor = min(left, right)
                    if nums[i] >= min_neighbor:
                        res += nums[i] - (min_neighbor - 1)
            return res

        return min(find_valleys(0), find_valleys(1))
