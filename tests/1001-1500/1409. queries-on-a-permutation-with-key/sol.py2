class Solution(object):
    def processQueries(self, queries, m):
        """
        :type queries: List[int]
        :type m: int
        :rtype: List[int]
        """
        arr = []
        ans = []
        for i in range(1, m + 1):
            arr.append(i)
        for x in queries:
            ans.append(arr.index(x))
            arr.remove(x)
            arr.insert(0, x)
        return ans
