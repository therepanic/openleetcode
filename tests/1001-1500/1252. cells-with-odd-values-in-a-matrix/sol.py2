class Solution(object):
    def oddCells(self, m, n, indices):
        """
        :type m: int
        :type n: int
        :type indices: List[List[int]]
        :rtype: int
        """
        a=[]
        c=0
        for i in range(m):
            l=[]
            for j in range(n):
                l.append(0)
            a.append(l)
        for k in indices:
            for u in range(n):
                a[k[0]][u]+=1
            for l in range(m):
                a[l][k[1]]+=1
        for i in a:
            for j in i:
                if j%2!=0:
                    c+=1
        return c
