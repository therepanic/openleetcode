class Solution(object):
    def maxEqualRowsAfterFlips(self, matrix):
        """
        :type matrix: List[List[int]]
        :rtype: int
        """
        from collections import defaultdict
        count = defaultdict(int)
        ans = 0

        for row in matrix:
            flip = row[0]
            key = tuple(x ^ flip for x in row)
            count[key] += 1
            if count[key] > ans:
                ans = count[key]

        return ans
