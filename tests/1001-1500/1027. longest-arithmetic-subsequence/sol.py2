class Solution(object):
    def longestArithSeqLength(self, nums):
        n = len(nums)
        if n <= 2:
            return n
        dp = [{} for _ in range(n)]
        ans = 2
        for i in range(n):
            for j in range(i):
                d = nums[i] - nums[j]
                prev = dp[j].get(d, 1)
                dp[i][d] = max(dp[i].get(d, 0), prev + 1)
                if dp[i][d] > ans:
                    ans = dp[i][d]
        return ans
