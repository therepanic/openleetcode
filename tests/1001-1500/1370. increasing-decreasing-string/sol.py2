class Solution(object):
    def sortString(self, s):
        """
        :type s: str
        :rtype: str
        """
        if not s:
            return ""
        from collections import Counter
        counts = Counter(s)
        keys = sorted(counts.keys(), key=lambda x: ord(x))
        ans = ""
        while max(counts.values()) > 0:
            for key in keys:
                if counts[key] > 0:
                    ans += key
                    counts[key] -= 1
            for key in reversed(keys):
                if counts[key] > 0:
                    ans += key
                    counts[key] -= 1
        return ans
