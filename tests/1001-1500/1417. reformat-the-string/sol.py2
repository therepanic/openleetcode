class Solution(object):
    def reformat(self, s):
        """
        :type s: str
        :rtype: str
        """
        digits = [c for c in s if c.isdigit()]
        letters = [c for c in s if c.isalpha()]
        if abs(len(digits) - len(letters)) >= 2:
            return ""
        ans = [None] * len(s)
        if len(digits) > len(letters):
            ans[::2] = digits
            ans[1::2] = letters
        else:
            ans[::2] = letters
            ans[1::2] = digits
        return "".join(ans)
