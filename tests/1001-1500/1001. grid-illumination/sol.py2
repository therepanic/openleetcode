class Solution(object):
    def gridIllumination(self, n, lamps, queries):
        """
        :type n: int
        :type lamps: List[List[int]]
        :type queries: List[List[int]]
        :rtype: List[int]
        """
        from collections import defaultdict
        row_count = defaultdict(int)
        col_count = defaultdict(int)
        diagonal1 = defaultdict(int)
        diagonal2 = defaultdict(int)
        lamp_set = set()
        ans = []
        directions = [(-1,-1), (-1,0), (-1,1), 
                      (0,-1),  (0,0),  (0,1), 
                      (1,-1),  (1,0),  (1,1)]
        for row, col in lamps:
            if (row, col) not in lamp_set:
                lamp_set.add((row, col))
                row_count[row] += 1
                col_count[col] += 1
                diagonal1[row - col] += 1
                diagonal2[row + col] += 1
        for row, col in queries:
            if row_count[row] or col_count[col] or diagonal1[row - col] or diagonal2[row + col]:
                ans.append(1)
                for dr, dc in directions:
                    nr, nc = row + dr, col + dc
                    if (nr, nc) in lamp_set:
                        lamp_set.remove((nr, nc))
                        row_count[nr] -= 1
                        col_count[nc] -= 1
                        diagonal1[nr - nc] -= 1
                        diagonal2[nr + nc] -= 1
            else:
                ans.append(0)
        return ans
