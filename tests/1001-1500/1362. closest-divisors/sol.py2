class Solution(object):
    def closestDivisors(self, num):
        """
        :type num: int
        :rtype: List[int]
        """
        import math
        start = int(math.sqrt(num + 2))
        for d in range(start, 0, -1):
            if (num + 1) % d == 0:
                return [d, (num + 1) // d]
            if (num + 2) % d == 0:
                return [d, (num + 2) // d]
        return []
