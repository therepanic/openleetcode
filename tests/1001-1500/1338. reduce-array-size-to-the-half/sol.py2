class Solution(object):
    def minSetSize(self, arr):
        """
        :type arr: List[int]
        :rtype: int
        """
        freq = {}
        for num in arr:
            freq[num] = freq.get(num, 0) + 1
        
        counts = sorted(freq.values(), reverse=True)
        
        sum_removed = 0
        min_set_size = 0
        for count in counts:
            sum_removed += count
            min_set_size += 1
            if sum_removed >= len(arr) // 2:
                return min_set_size
        return min_set_size
