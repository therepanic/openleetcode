class Solution(object):
    def maxSumAfterPartitioning(self, arr, k):
        n = len(arr)
        dp = [0] * (n + 1)
        for i in range(1, n + 1):
            curr = 0
            for j in range(1, k + 1):
                if i < j:
                    break
                curr = max(curr, arr[i - j])
                dp[i] = max(dp[i], dp[i - j] + curr * j)
        return dp[n]
