class Solution(object):
    def kthFactor(self, n, k):
        """
        :type n: int
        :type k: int
        :rtype: int
        """
        ab = []
        for i in range(1, n + 1):
            if n % i == 0:
                ab.append(i)
        if len(ab) < k:
            return -1
        else:
            return ab[k - 1]
