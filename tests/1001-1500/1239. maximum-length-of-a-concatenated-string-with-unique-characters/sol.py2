class Solution(object):
    def maxLength(self, arr):
        """
        :type arr: List[str]
        :rtype: int
        """
        n = len(arr)
        self.ans = 0
        
        def dfs(i, path):
            self.ans = max(self.ans, len(path))
            for j in range(i, n):
                if len(set(arr[j])) != len(arr[j]) or set(path) & set(arr[j]):
                    continue
                dfs(j + 1, path + arr[j])
        
        dfs(0, "")
        return self.ans
