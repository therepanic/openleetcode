class Solution(object):
    def mctFromLeafValues(self, arr):
        """
        :type arr: List[int]
        :rtype: int
        """
        result = 0
        st = [float('inf')]

        for a in arr:
            while st[-1] <= a:
                mid = st.pop()
                result += mid * min(st[-1], a)
            st.append(a)

        first = st.pop()
        while len(st) > 1:
            result += first * st[-1]
            first = st.pop()

        return result
