class Solution(object):
    def buildArray(self, target, n):
        s=[]
        res=[]
        a=0
        for i in range(1,n+1):
            if s==target:
                return res
            s.append(i)
            res.append("Push")
            if s[a]!=target[a]:
                s.pop()
                res.append("Pop")
            else:
                a=a+1
        return res
