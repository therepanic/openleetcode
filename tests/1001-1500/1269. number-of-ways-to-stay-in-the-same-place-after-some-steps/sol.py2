class Solution(object):
    def numWays(self, steps, arrLen):
        """
        :type steps: int
        :type arrLen: int
        :rtype: int
        """
        MOD = 10**9 + 7
        maxPos = min(steps // 2, arrLen - 1)
        dp = [0] * (maxPos + 1)
        dp[0] = 1
        for step in range(steps):
            newDp = [0] * (maxPos + 1)
            for pos in range(maxPos + 1):
                if dp[pos] == 0:
                    continue
                newDp[pos] = (newDp[pos] + dp[pos]) % MOD
                if pos > 0:
                    newDp[pos - 1] = (newDp[pos - 1] + dp[pos]) % MOD
                if pos < maxPos:
                    newDp[pos + 1] = (newDp[pos + 1] + dp[pos]) % MOD
            dp = newDp
        return dp[0]
