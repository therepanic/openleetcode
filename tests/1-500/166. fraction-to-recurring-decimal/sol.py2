class Solution(object):
    def fractionToDecimal(self, numerator, denominator):
        if numerator == 0:
            return '0'
        result = []
        if (numerator < 0) ^ (denominator < 0):
            result.append('-')
        numerator, denominator = abs(long(numerator)), abs(long(denominator))
        result.append(str(numerator // denominator))
        rem = numerator % denominator
        if rem == 0:
            return ''.join(result)
        result.append('.')
        seen = {}
        while rem:
            if rem in seen:
                result.insert(seen[rem], '(')
                result.append(')')
                break
            seen[rem] = len(result)
            rem *= 10
            result.append(str(rem // denominator))
            rem %= denominator
        return ''.join(result)
