class Solution(object):
    def calculate(self, s):
        """
        :type s: str
        :rtype: int
        """
        stack = []
        n = 0
        op = '+'
        s += '+'
        
        for c in s:
            if c == ' ':
                continue
                
            if c.isdigit():
                n = n * 10 + int(c)
                continue
                
            if op == '+':
                stack.append(n)
            elif op == '-':
                stack.append(-n)
            elif op == '*':
                stack.append(stack.pop() * n)
            elif op == '/':
                stack.append(int(stack.pop() / float(n)))
                
            op = c
            n = 0
            
        return sum(stack)
