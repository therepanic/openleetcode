class Solution(object):
    def longestPalindrome(self, s):
        if not s:
            return ""

        def expand(left, right):
            while left >= 0 and right < len(s) and s[left] == s[right]:
                left -= 1
                right += 1
            return right - left - 1

        start = 0
        best = 1
        for i in range(len(s)):
            length = max(expand(i, i), expand(i, i + 1))
            if length > best:
                best = length
                start = i - (length - 1) // 2

        return s[start:start + best]
