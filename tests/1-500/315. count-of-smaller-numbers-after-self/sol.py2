from sortedcontainers import SortedList
class Solution(object):
    def countSmaller(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        sorted_list = SortedList()
        ans = []
        for n in reversed(nums):
            ans.append(sorted_list.bisect_left(n))
            sorted_list.add(n)
        ans.reverse()
        return ans
