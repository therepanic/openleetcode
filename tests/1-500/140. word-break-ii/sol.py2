class Solution(object):
    def wordBreak(self, s, wordDict):
        words = set(wordDict)
        memo = {}
        def solve(text):
            if text in memo:
                return memo[text]
            result = []
            if text in words:
                result.append(text)
            for i in xrange(1, len(text)):
                prefix = text[:i]
                if prefix in words:
                    for tail in solve(text[i:]):
                        result.append(prefix + ' ' + tail)
            memo[text] = result
            return result
        return solve(s)
