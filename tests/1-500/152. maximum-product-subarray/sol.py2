class Solution(object):
    def maxProduct(self, nums):
        best = max(nums)
        cur_max = 1
        cur_min = 1
        for x in nums:
            temp = cur_max * x
            cur_max = max(temp, cur_min * x, x)
            cur_min = min(temp, cur_min * x, x)
            best = max(best, cur_max)
        return best
