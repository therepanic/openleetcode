class Solution(object):
    def decodeString(self, s):
        """
        :type s: str
        :rtype: str
        """
        self.i = 0
        return self.decode(s)
    
    def decode(self, s):
        res = ""
        num = 0
        while self.i < len(s):
            c = s[self.i]
            if c.isdigit():
                num = num * 10 + int(c)
                self.i += 1
            elif c == '[':
                self.i += 1
                inner = self.decode(s)
                res += inner * num
                num = 0
            elif c == ']':
                self.i += 1
                return res
            else:
                res += c
                self.i += 1
        return res
