class Solution:
    def combinationSum(self, candidates, target):
        candidates.sort()
        res = []

        def backtrack(start, total, cur):
            if total == target:
                res.append(cur[:])
                return
            for i in range(start, len(candidates)):
                if total + candidates[i] > target:
                    break
                cur.append(candidates[i])
                backtrack(i, total + candidates[i], cur)
                cur.pop()

        backtrack(0, 0, [])
        return res
