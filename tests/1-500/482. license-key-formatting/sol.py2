class Solution(object):
    def licenseKeyFormatting(self, s, k):
        """
        :type s: str
        :type k: int
        :rtype: str
        """
        s = s.replace("-", "").upper()
        result = []
        for i in range(len(s), 0, -k):
            result.append(s[max(0, i - k):i])
        return "-".join(result[::-1])
