class Solution:
    def letterCombinations(self, digits):
        if not digits:
            return []
        maps = {'2': 'abc', '3': 'def', '4': 'ghi', '5': 'jkl', '6': 'mno', '7': 'pqrs', '8': 'tuv', '9': 'wxyz'}
        res = []
        cur = []
        def dfs(idx):
            if idx == len(digits):
                res.append(''.join(cur))
                return
            for ch in maps[digits[idx]]:
                cur.append(ch)
                dfs(idx + 1)
                cur.pop()
        dfs(0)
        return res
