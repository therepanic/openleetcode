class Solution(object):
    def summaryRanges(self, nums):
        """
        :type nums: List[int]
        :rtype: List[str]
        """
        result = []
        i = 0
        
        while i < len(nums):
            start = nums[i]
            j = i
            while j + 1 < len(nums) and nums[j + 1] == nums[j] + 1:
                j += 1
            
            if nums[j] == start:
                result.append(str(start))
            else:
                result.append("{}->{}".format(start, nums[j]))
            
            i = j + 1
        
        return result
