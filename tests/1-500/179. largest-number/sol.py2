class Solution(object):
    def largestNumber(self, nums):
        parts = [str(num) for num in nums]

        def cmp(a, b):
            ab = a + b
            ba = b + a
            if ab > ba:
                return -1
            if ab < ba:
                return 1
            return 0

        parts.sort(cmp=cmp)
        if parts and parts[0] == "0":
            return "0"
        return "".join(parts)
