
class Solution(object):
    def numDistinct(self, s, t):
        if len(t) > len(s):
            return 0
        dp = [0] * (len(t) + 1)
        dp[0] = 1
        for ch in s:
            for j in xrange(len(t) - 1, -1, -1):
                if ch == t[j]:
                    dp[j + 1] += dp[j]
        return dp[len(t)]
