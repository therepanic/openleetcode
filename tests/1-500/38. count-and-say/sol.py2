class Solution:
    def countAndSay(self, n):
        current = "1"
        for _ in range(1, n):
            next_value = ""
            i = 0
            while i < len(current):
                j = i
                while j < len(current) and current[j] == current[i]:
                    j += 1
                next_value += str(j - i) + current[i]
                i = j
            current = next_value
        return current
