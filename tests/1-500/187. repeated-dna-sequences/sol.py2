class Solution(object):
    def findRepeatedDnaSequences(self, s):
        seen = {}
        ans = []
        for i in xrange(len(s) - 9):
            sub = s[i:i + 10]
            count = seen.get(sub, 0)
            if count == 1:
                ans.append(sub)
            seen[sub] = count + 1
        return ans
