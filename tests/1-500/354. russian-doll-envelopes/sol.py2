class Solution(object):
    def maxEnvelopes(self, envelopes):
        """
        :type envelopes: List[List[int]]
        :rtype: int
        """
        import bisect
        envelopes.sort(key=lambda x: (x[0], -x[1]))
        result = []
        for _, e in envelopes:
            idx = bisect.bisect_left(result, e)
            if idx == len(result):
                result.append(e)
            else:
                result[idx] = e
        return len(result)
