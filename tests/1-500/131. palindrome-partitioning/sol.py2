class Solution(object):
    def partition(self, s):
        result = []
        path = []
        def is_palindrome(left, right):
            while left < right:
                if s[left] != s[right]:
                    return False
                left += 1
                right -= 1
            return True
        def backtrack(index):
            if index == len(s):
                result.append(path[:])
                return
            for end in xrange(index, len(s)):
                if is_palindrome(index, end):
                    path.append(s[index:end + 1])
                    backtrack(end + 1)
                    path.pop()
        backtrack(0)
        return result
