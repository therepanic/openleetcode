class Solution(object):
    def wordBreak(self, s, wordDict):
        words = set(wordDict)
        max_len = max(len(word) for word in wordDict)
        n = len(s)
        dp = [False] * (n + 1)
        dp[n] = True
        for i in xrange(n - 1, -1, -1):
            for j in xrange(i + 1, min(i + max_len, n) + 1):
                if s[i:j] in words and dp[j]:
                    dp[i] = True
                    break
        return dp[0]
