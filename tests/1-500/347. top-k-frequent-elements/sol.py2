class Solution(object):
    def topKFrequent(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: List[int]
        """
        freq = {}
        first = {}
        for i, x in enumerate(nums):
            if x not in freq:
                freq[x] = 0
                first[x] = i
            freq[x] += 1
        return [x for x, _ in sorted(freq.items(), key=lambda item: (-item[1], first[item[0]]))[:k]]
