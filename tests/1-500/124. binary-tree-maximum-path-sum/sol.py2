class Solution(object):
    def maxPathSum(self, root):
        self.best = root.val

        def dfs(node):
            if node is None:
                return 0
            left = max(dfs(node.left), 0)
            right = max(dfs(node.right), 0)
            self.best = max(self.best, node.val + left + right)
            return node.val + max(left, right)

        dfs(root)
        return self.best
