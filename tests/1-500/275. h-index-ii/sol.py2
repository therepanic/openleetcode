class Solution(object):
    def hIndex(self, citations):
        """
        :type citations: List[int]
        :rtype: int
        """
        n = len(citations)
        l = 0
        r = n
        while l < r:
            m = (l + r + 1) // 2
            if citations[n - m] >= m:
                l = m
            else:
                r = m - 1
        return l
