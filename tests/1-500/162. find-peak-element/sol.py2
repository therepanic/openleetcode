class Solution(object):
    def findPeakElement(self, nums):
        n = len(nums)
        if n < 3:
            return nums.index(max(nums))
        left, right = 0, len(nums) - 1
        while left < right:
            mid = (left + right) // 2
            if mid > 0 and mid < n - 1 and nums[mid - 1] < nums[mid] > nums[mid + 1]:
                return mid
            if nums[mid] < nums[mid + 1]:
                left = mid + 1
            else:
                right = mid
        return left
