class Solution:
    def searchRange(self, nums, target):
        def bound(left):
            low = 0
            high = len(nums) - 1
            ans = -1
            while low <= high:
                mid = (low + high) // 2
                if nums[mid] < target:
                    low = mid + 1
                elif nums[mid] > target:
                    high = mid - 1
                else:
                    ans = mid
                    if left:
                        high = mid - 1
                    else:
                        low = mid + 1
            return ans

        return [bound(True), bound(False)]
