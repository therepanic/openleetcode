class Solution(object):
    def myAtoi(self, s):
        s = s.strip()
        if not s:
            return 0

        sign, i, res = 1, 0, 0
        if s[0] == '-':
            sign = -1
            i += 1
        elif s[0] == '+':
            i += 1

        while i < len(s) and s[i].isdigit():
            digit = int(s[i])
            if sign == 1:
                if res > 214748364 or (res == 214748364 and digit > 7):
                    return 2147483647
            else:
                if res > 214748364 or (res == 214748364 and digit > 8):
                    return -2147483648
            res = res * 10 + digit
            i += 1

        return sign * res
