class Solution(object):
    def insertionSortList(self, head):
        values = []
        cur = head
        while cur:
            values.append(cur.val)
            cur = cur.next
        values.sort()
        dummy = ListNode(0)
        tail = dummy
        for value in values:
            tail.next = ListNode(value)
            tail = tail.next
        return dummy.next
