class Solution:
    def jump(self, nums):
        n = len(nums)
        if n <= 1:
            return 0

        jumps = 0
        curr_end = 0
        max_reach = 0

        for i in range(n - 1):
            max_reach = max(max_reach, i + nums[i])
            if i == curr_end:
                jumps += 1
                curr_end = max_reach
                if curr_end >= n - 1:
                    break

        return jumps
