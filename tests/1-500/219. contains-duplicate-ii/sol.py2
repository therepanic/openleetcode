class Solution(object):
    def containsNearbyDuplicate(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: bool
        """
        window_set = set()
        
        for i in range(len(nums)):
            if i > k:
                window_set.remove(nums[i - k - 1])
            
            if nums[i] in window_set:
                return True
            
            window_set.add(nums[i])
            
        return False
