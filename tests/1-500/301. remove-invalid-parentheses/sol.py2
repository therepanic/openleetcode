class Solution(object):
    def removeInvalidParentheses(self, s):
        """
        :type s: str
        :rtype: List[str]
        """
        def isValid(string):
            ctr = 0
            for ch in string:
                if ch == '(':
                    ctr += 1
                elif ch == ')':
                    if ctr == 0:
                        return False
                    ctr -= 1
            return ctr == 0
        
        level = {s}
        while True:
            valid = [string for string in level if isValid(string)]
            if valid:
                return valid
            level = {string[:i] + string[i+1:] for string in level for i in range(len(string))}
